{
  "name": "dtm-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DeFi Transparency Microscope - backend service (Fastify + ethers.js)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts --report-unused-disable-directives",
    "format": "prettier --write \"src/**/*.{ts,css,md}\" \"tests/**/*.{ts,css,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "fastify": "^4.28.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^8.57.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3",
    "vitest": "^2.1.2"
  }
}
