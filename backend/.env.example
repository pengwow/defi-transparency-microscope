# Server
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info
ENV=dev

# Chain (Ethereum mainnet default)
RPC_URL=https://eth.llamarpc.com
RPC_WS_URL=
CHAIN_ID=1

# Caching / polling
CACHE_TTL_MS=5000
LIQUIDATION_POLL_MS=12000
LIQUIDATION_LOOKBACK=100
AMM_SYNC_POLL_MS=12000
AMM_SYNC_LOOKBACK=100
AMM_SYNC_DEBOUNCE_MS=250

# CORS allow-list (comma-separated origins).  Special values:
#   - unset / empty  → dev defaults (http://localhost:5173, http://127.0.0.1:5173)
#   - "*"            → any origin (forces CORS_ALLOW_ALL=true)
#   - otherwise      → exact-match allow-list (no wildcards)
# Example for prod:
# CORS_ORIGINS=https://dtm.example.com,https://staging.dtm.example.com
# CORS_ALLOW_ALL=false

