# Ethereum mainnet HTTP RPC endpoint (required)
RPC_URL=https://eth.llamarpc.com

# Optional WebSocket RPC for mempool subscriptions (falls back to HTTP polling)
RPC_WS_URL=

# Server port
PORT=8000

# Chain ID (1 = Ethereum mainnet)
CHAIN_ID=1

# pino log level (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# In-memory read cache TTL in milliseconds
CACHE_TTL_MS=5000
