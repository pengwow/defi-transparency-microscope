# Ethereum mainnet HTTP RPC endpoint (required)
RPC_URL=https://eth.llamarpc.com

# Optional WebSocket RPC for mempool subscriptions (falls back to HTTP polling)
RPC_WS_URL=

# Server port
PORT=8000

# Chain ID (1 = Ethereum mainnet)
CHAIN_ID=1

# pino log level (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# In-memory read cache TTL in milliseconds
CACHE_TTL_MS=5000

# CORS allow-list (comma-separated origins).  Special values:
#   - unset / empty  → dev defaults (http://localhost:5173, http://127.0.0.1:5173)
#   - "*"            → any origin
#   - otherwise      → exact-match allow-list (no wildcards)
# Example for prod:
# CORS_ORIGINS=https://dtm.example.com,https://staging.dtm.example.com

