# Frontend environment configuration.
# Copy this file to `.env.local` (gitignored) and adjust as needed.
# All variables must be prefixed with VITE_ to be exposed to the client.

# When set to "true" the app talks to the real backend (see VITE_BACKEND_URL)
# via the HttpAPI implementation of DataAPI.  When unset / any other value
# the app uses the in-browser MockAPI (default, safe for offline development).
VITE_USE_BACKEND=false

# Base URL of the dtm-backend REST service.  Used by HttpAPI when
# VITE_USE_BACKEND=true.  Trailing slash is optional.
VITE_BACKEND_URL=http://localhost:8000
