# DTM Frontend ‚Äî environment configuration
#
# Copy this file to `frontend/.env.local` and uncomment / edit the
# lines you need.  Vite reads `.env.local` automatically; the
# variables here only need the `VITE_` prefix to be exposed to the
# browser bundle (per Vite convention).
#
#   cp .env.example .env.local
#
# Reference: https://vitejs.dev/guide/env-and-mode.html#env-files

# ‚îÄ‚îÄ‚îÄ Backend switch ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
#
# `false` (default)  ‚Üí the in-memory `MockAPI` from `src/services/mockApi.ts`
#                      drives every page.  No network traffic; deterministic
#                      data, perfect for offline demos.
#
# `true`             ‚Üí the real `HttpAPI` from `src/services/httpApi.ts` is
#                      used for the REST surface, and the `WsClient` from
#                      `src/services/wsClient.ts` opens a WebSocket to
#                      `${VITE_BACKEND_URL}/ws` for mempool / amm_sync /
#                      liquidation_event pushes.
#
# Set this to `true` to point the UI at the FastAPI backend in
# `../backend` (run with `uv run dtm-backend` from the repo root).
VITE_USE_BACKEND=false

# Backend origin.  Default points at the production-style dev server
# on port 8000.  Use port 8765 if you boot the offline e2e stub
# instead (`uv run dtm-e2e-server`).
#
# Must NOT include a trailing slash.  CORS is allowed by the
# backend for the standard Vite ports (5173, 4173, 5174, 5175)
# plus the CRA/Next dev ports (3000, 8080); if you run on a
# different port, either add it to `CORS_ORIGINS` in
# `backend/.env.local` or set `CORS_ALLOW_ALL=true` for a quick
# dev-only escape hatch.
VITE_BACKEND_URL=http://localhost:8000
